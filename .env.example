# Grafana
GRAFANA_ADMIN_USER=user_name
GRAFANA_ADMIN_PASSWORD=your_secure_password_here

# PostgreSQL
POSTGRES_USER=user_name
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=db_name

# Auth Service
AUTH_PORT=8081
AUTH_GRPC_PORT=50051

# Tasks Service
TASKS_PORT=8082
AUTH_GRPC_ADDR=auth:50051
DB_HOST=postgres
DB_PORT=5432
DB_NAME=db_name
DB_SSLMODE=disable

# RabbitMQ
RABBITMQ_URL=your_url_here
RABBITMQ_QUEUE=task_events
RABBITMQ_PREFETCH=1
WORKER_ID=worker-1