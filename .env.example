# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_password_here

# PostgreSQL
POSTGRES_USER=appuser
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=tasksdb

# Auth Service
AUTH_PORT=8081
AUTH_GRPC_PORT=50051

# Tasks Service
TASKS_PORT=8082
AUTH_GRPC_ADDR=auth:50051
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tasksdb
DB_SSLMODE=disable